<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #e0f7fa, #ffffff);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.messenger.server.controller.ServerController">
   <children>
      <HBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #555555; -fx-font-size: 14px;" text="Системні логи сервера:" />
                  <TextArea fx:id="serverLogsArea" editable="false" prefHeight="250.0" style="-fx-font-size: 14px; -fx-control-inner-background: white; -fx-border-color: #b0bec5; -fx-border-radius: 5;" wrapText="true" VBox.vgrow="ALWAYS" />
                  
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #555555; -fx-font-size: 14px;" text="👁 Моніторинг всіх чатів:" />
                  <ScrollPane fitToWidth="true" prefHeight="350.0" style="-fx-background: white; -fx-background-color: white; -fx-border-color: #b0bec5; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="monitoringBox" spacing="8.0" style="-fx-background-color: white; -fx-padding: 10;" />
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            
            <VBox minWidth="300.0" prefWidth="350.0" spacing="10.0">
               <children>
                  <TextField fx:id="searchField" promptText="🔍 Пошук клієнтів онлайн..." style="-fx-font-size: 16px; -fx-background-radius: 5;" />
                  <ListView fx:id="activeSessionsList" style="-fx-font-size: 16px; -fx-border-color: #b0bec5; -fx-border-radius: 5;" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>